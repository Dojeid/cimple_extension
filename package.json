{
  "name": "cimple-language",
  "displayName": "Cimple",
  "icon": "resources/images/cimple_icon-removebg.png",
  "description": "Professional Python-compatible syntax highlighting and build support for the Cimple language.",
  "version": "0.0.5",
  "author": "Cimple Industries",
  "publisher": "Cimple-Industries",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "vsix": "vsce package --allow-missing-repository --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "@vscode/test-electron": "^2.4.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "cimple.buildAndRun",
        "title": "Cimple: Build and Run Active File"
      }
    ],
    "languages": [
      {
        "id": "cimple",
        "aliases": [
          "Cimple",
          "cimple"
        ],
        "extensions": [
          ".cimp"
        ],
        "icon": {
          "light": "./resources/images/cimple_icon-removebg.png",
          "dark": "./resources/images/cimple_icon-removebg.png"
        },
        "configuration": "./resources/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cimple",
        "scopeName": "source.cimple",
        "path": "./resources/syntaxes/cimple.tmLanguage.json"
      }
    ],
    "debuggers": [
      {
        "type": "cimple",
        "label": "Cimple Debug",
        "languages": [
          "cimple"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {}
          }
        },
        "initialConfigurations": [
          {
            "type": "cimple",
            "name": "Cimple: Run Active File",
            "request": "launch"
          }
        ]
      }
    ]
  }
}