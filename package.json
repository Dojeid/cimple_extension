{
  "name": "cimple-language",
  "displayName": "Cimple",
  "description": "Python-based Cimple syntax highlighting for Visual Studio Code.",
  "version": "0.0.1",
  "publisher": "cimple",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:cimple"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepare": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.9.6",
    "@types/vscode": "^1.128.0",
    "tslib": "^2.6.2",
    "typescript": "^5.5.2",
    "vscode-test": "^2.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "cimple",
        "aliases": [
          "Cimple",
          "cimple"
        ],
        "extensions": [
          ".cimp",
          ".csc",
          ".cimple"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cimple",
        "scopeName": "source.cimple",
        "path": "./syntaxes/cimple.tmLanguage.json"
      }
    ]
  }
}
