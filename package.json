{
  "name": "cimple-language",
  "displayName": "Cimple",
  "icon": "images/cimple_icon-removebg.png",
  "description": "Python-based Cimple syntax highlighting for Visual Studio Code.",
  "version": "0.0.2",
  "publisher": "Cimple-Industries",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:cimple",
    "onCommand:cimple.buildAndRun"
  ],
  "main": "./extension.js",
  "scripts": {
    "vsix": "vsce package --allow-missing-repository --no-dependencies"
  },
  "contributes": {
    "commands": [
      {
        "command": "cimple.buildAndRun",
        "title": "Cimple: Build and Run Active File"
      }
    ],
    "keybindings": [
      {
        "command": "cimple.buildAndRun",
        "key": "f5",
        "when": "editorLangId == cimple"
      }
    ],
    "languages": [
      {
        "id": "cimple",
        "aliases": [
          "Cimple",
          "cimple"
        ],
        "extensions": [
          ".cimp"
        ],
        "icon": {
          "light": "./images/cimple_icon-removebg.png",
          "dark": "./images/cimple_icon-removebg.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cimple",
        "scopeName": "source.cimple",
        "path": "./syntaxes/cimple.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "cimple-icons",
        "label": "Cimple Icons",
        "path": "./icons/cimple-icons.json"
      }
    ]
  }
}
